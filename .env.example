# Copy to `.env.local` for local dev. In Vercel: Project → Environment Variables.
# Get a public token (pk.*) from https://account.mapbox.com/access-tokens/
# Mapbox URL restrictions must include your site (e.g. https://*.vercel.app/*).
VITE_MAPBOX_ACCESS_TOKEN=pk.your_mapbox_token_here

# Gemini — "Analyze image" in pothole details (optional).
# Production: use a small backend URL and leave the key off the client:
#   VITE_GEMINI_PROXY_URL=https://your-api.example.com/gemini/analyze-road-image
# Local / thesis demos only (key ships in the browser bundle). Prefer an AI Studio key:
# https://aistudio.google.com/app/apikey — Google Cloud keys with API restrictions may get 403 API_KEY_SERVICE_BLOCKED.
#   VITE_GEMINI_API_KEY=
# Optional: override model id (default follows Gemini 3.1 Flash-Lite guide).
# @see https://ai.google.dev/gemini-api/docs/models/gemini-3.1-flash-lite — stable id: gemini-3.1-flash-lite
#   VITE_GEMINI_MODEL=gemini-3.1-flash-lite
